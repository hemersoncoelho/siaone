# ======================================
# Sia One - .gitignore
# ======================================

# ---- Node.js / NPM ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ---- Build outputs ----
dist/
build/
.output/
out/

# ---- Environment variables (NUNCA subir!) ----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.env

# ---- IDE / Editor ----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ---- Logs ----
logs/
*.log

# ---- Cache ----
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# ---- Temporários ----
tmp/
temp/

# ---- Supabase (manter apenas migrations) ----
supabase/.temp/
supabase/functions/.cache/

# ---- Documentos Word (arquivos de briefing, não código) ----
*.docx
*.doc
*.pdf
